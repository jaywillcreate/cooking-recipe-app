# ─────────────────────────────────────────────────────────────
# Ember (Next.js full-stack) — environment
# Local: copy to `.env.local`. On Vercel: add each as a Project → Environment
# Variable. NEVER commit real values.
# ─────────────────────────────────────────────────────────────

# ─── Database (Prisma Postgres on Vercel) ───
# Use the DIRECT TCP connection string (postgres://…@db.prisma.io:5432/?sslmode=require)
# for the app AND for migrations. NOT the prisma+postgres://…accelerate… URL.
DATABASE_URL=postgres://USER:PASSWORD@db.prisma.io:5432/?sslmode=require
PGSSLMODE=require

# ─── Secrets — generate each with: openssl rand -hex 32 ───
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ADMIN_SESSION_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ─── Anthropic (Claude) — powers recipe generation ───
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_MAX_TOKENS=2500
GEN_DAILY_LIMIT=25

# ─── Email (daily recipe delivery) ───
# "console" just logs (dev). "resend" sends via Resend.
EMAIL_PROVIDER=console
EMAIL_FROM=Ember <hello@yourdomain.com>
RESEND_API_KEY=

# ─── Vercel Cron (daily automation) ───
# Set the SAME value in Vercel → Settings → Environment Variables as CRON_SECRET.
# Vercel Cron sends it automatically; the endpoint rejects anything else.
CRON_SECRET=

# ─── Vercel Blob (photo storage) ───
# Auto-injected once you link a Blob store on Vercel. For local uploads, paste it here.
BLOB_READ_WRITE_TOKEN=

# ─── Public origin (email links). Optional — defaults to VERCEL_URL. ───
APP_ORIGIN=http://localhost:3000

# ─── Optional: restrict which domains users may follow (SSRF hardening) ───
SITE_ALLOWLIST=
